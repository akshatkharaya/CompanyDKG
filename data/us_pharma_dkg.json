    {"id": "team_supplier_mgmt", "name": "Supplier Management", "department": "Commercial", "headcount": 28, "description": "Negotiates manufacturer contracts and rebate agreements."},
    {"id": "team_credit", "name": "Credit Risk", "department": "Finance", "headcount": 14, "description": "Approves customer credit limits and payment terms."},
    {"id": "team_collections", "name": "AR Collections", "department": "Finance", "headcount": 20, "description": "Manages collection actions on overdue receivables."},
    {"id": "team_fpa", "name": "FP&A", "department": "Finance", "headcount": 16, "description": "Produces forecasts, budgets, and management reporting."},
    {"id": "team_treasury", "name": "Treasury", "department": "Finance", "headcount": 8, "description": "Manages cash, liquidity, and short-term funding."},
    {"id": "team_capex", "name": "Capital Planning", "department": "Finance", "headcount": 6, "description": "Reviews and approves capital expenditure proposals."},
    {"id": "team_compliance", "name": "Regulatory Compliance", "department": "Legal/Compliance", "headcount": 12, "description": "Owns DEA, FDA, and state-level regulatory reporting."}
