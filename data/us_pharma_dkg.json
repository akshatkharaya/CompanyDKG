  "constraints": [
    {"id": "con_safety_min", "name": "Contractual safety stock minimums", "constraint_type": "contractual", "enforcement": "hard", "owner_team_id": "team_supplier_mgmt", "description": "Manufacturer SLAs require minimum stock levels for select drugs."},
    {"id": "con_dc_capacity", "name": "DC storage capacity", "constraint_type": "physical", "enforcement": "hard", "owner_team_id": "team_warehouse_ops", "description": "Each DC has a fixed cubic capacity; cannot exceed it."},
    {"id": "con_dea_quotas", "name": "DEA controlled substance quotas", "constraint_type": "regulatory", "enforcement": "hard", "owner_team_id": "team_compliance", "description": "Annual DEA quota limits on controlled substance distribution."},
    {"id": "con_min_cash_buffer", "name": "Minimum cash buffer policy", "constraint_type": "policy", "enforcement": "hard", "owner_team_id": "team_treasury", "description": "Maintain at least $X minimum operating cash on hand."},
    {"id": "con_capex_threshold", "name": "Capex approval thresholds", "constraint_type": "policy", "enforcement": "hard", "owner_team_id": "team_capex", "description": "Projects above $1M require CFO approval; above $10M require board approval."},
    {"id": "con_credit_policy", "name": "Customer credit policy limits", "constraint_type": "policy", "enforcement": "soft", "owner_team_id": "team_credit", "description": "Default credit limits by customer tier; can be overridden with approval."},
    {"id": "con_carrier_contracts", "name": "Carrier contract commitments", "constraint_type": "contractual", "enforcement": "soft", "owner_team_id": "team_logistics", "description": "Minimum volume commitments to preferred carriers."},
    {"id": "con_price_floor", "name": "Cost-plus pricing floor", "constraint_type": "policy", "enforcement": "hard", "owner_team_id": "team_pricing", "description": "Customer prices cannot fall below cost + minimum margin."}
