  "decisions": [
    {"id": "dec_place_po", "name": "Place weekly POs with manufacturers", "cadence": "weekly", "decision_type": "operational", "output_type": "purchase_order", "automation_level": "partial", "description": "Decide quantity and timing for replenishment POs across SKU portfolio."},
    {"id": "dec_demand_forecast", "name": "Weekly SKU-level demand forecast", "cadence": "weekly", "decision_type": "operational", "output_type": "forecast", "automation_level": "partial", "description": "Produce 13-week rolling demand forecast at SKU/DC level."},
    {"id": "dec_warehouse_schedule", "name": "Daily warehouse labor & throughput plan", "cadence": "daily", "decision_type": "operational", "output_type": "schedule", "automation_level": "partial", "description": "Allocate labor and equipment to meet daily order volume."},
    {"id": "dec_route_plan", "name": "Daily delivery route optimization", "cadence": "daily", "decision_type": "operational", "output_type": "route_plan", "automation_level": "full", "description": "Optimize delivery routes for cost and on-time performance."},
    {"id": "dec_price_change", "name": "Customer pricing changes", "cadence": "monthly", "decision_type": "financial", "output_type": "price_update", "automation_level": "manual", "description": "Adjust customer-specific list prices and contract pricing."},
    {"id": "dec_supplier_negotiation", "name": "Supplier contract negotiation", "cadence": "quarterly", "decision_type": "strategic", "output_type": "contract", "automation_level": "manual", "description": "Negotiate volume, pricing, and rebate terms with manufacturers."},
    {"id": "dec_credit_limit", "name": "Customer credit limit approval", "cadence": "ad_hoc", "decision_type": "financial", "output_type": "approval", "automation_level": "partial", "description": "Set or change customer credit limits and payment terms."},
    {"id": "dec_collections_action", "name": "AR collections action", "cadence": "weekly", "decision_type": "financial", "output_type": "action_list", "automation_level": "partial", "description": "Decide which overdue accounts to escalate (call, hold shipments, legal)."},
    {"id": "dec_cash_forecast", "name": "Daily cash flow forecast", "cadence": "daily", "decision_type": "financial", "output_type": "forecast", "automation_level": "partial", "description": "13-week rolling cash forecast for the BU."},
    {"id": "dec_cash_coverage", "name": "Cash coverage & funding decision", "cadence": "daily", "decision_type": "financial", "output_type": "funding_action", "automation_level": "manual", "description": "Decide whether to draw on credit, invest excess cash, or take other liquidity actions."},
    {"id": "dec_capex_approval", "name": "Capital expenditure approval", "cadence": "monthly", "decision_type": "strategic", "output_type": "approval", "automation_level": "manual", "description": "Review and approve capital project proposals above threshold."},
    {"id": "dec_dea_reporting", "name": "Controlled substance suspicious order reporting", "cadence": "daily", "decision_type": "compliance", "output_type": "report", "automation_level": "partial", "description": "Identify and report suspicious orders of controlled substances to DEA."}
