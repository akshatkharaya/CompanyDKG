{
  "teams": [
    {"id": "team_inv_purchasing", "name": "Inventory Purchasing", "department": "Operations", "headcount": 35, "description": "Owns weekly PO placement decisions across all SKUs."},
    {"id": "team_demand_planning", "name": "Demand Planning", "department": "Operations", "headcount": 18, "description": "Produces weekly demand forecasts feeding inventory and warehouse decisions."},
