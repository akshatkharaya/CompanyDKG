    {"id": "exc_credit_drawdown", "name": "Unplanned credit facility drawdown", "trigger_condition": "Cash < min buffer + 7 days projected outflow", "raised_by_team_id": "team_treasury", "resolution_type": "manual_override", "frequency": "rare"},
    {"id": "exc_weather_disruption", "name": "Weather-related distribution disruption", "trigger_condition": "Severe weather warning in DC region", "raised_by_team_id": "team_logistics", "resolution_type": "auto_adjust", "frequency": "occasional"},
    {"id": "exc_dea_flag", "name": "Suspicious order pattern flagged", "trigger_condition": "Order volume >3 sigma above customer baseline", "raised_by_team_id": "team_compliance", "resolution_type": "escalation", "frequency": "occasional"}
