  "exceptions": [
    {"id": "exc_dsi_directive", "name": "CFO DSI reduction directive", "trigger_condition": "DSI exceeds target by 15%", "raised_by_team_id": "team_fpa", "resolution_type": "manual_override", "frequency": "occasional", "description": "Top-down directive to delay POs and reduce inventory days."},
